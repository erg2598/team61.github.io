                                 <columns>
                                    <TableColumn fx:id="nameSalesReport" prefWidth="180.0" text="name" />
                                    <TableColumn fx:id="itemIdSalesReport" prefWidth="180.0" text="itemId" />
                                    <TableColumn fx:id="totalSold" prefWidth="180.0" text="Total Sold" />
                                 </columns>
                              </TableView>
                           </children>
                        </AnchorPane>
                     </content>
                  </TitledPane>
              </panes>
            </Accordion>
            <Button layoutX="465.0" layoutY="400.0" mnemonicParsing="false" onAction="#returnHome" text="Return Home" />
         </children>
      </AnchorPane>
   </children>
</VBox>
