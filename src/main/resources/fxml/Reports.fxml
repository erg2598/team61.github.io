<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.boba.ReportController">
  <children>
    <AnchorPane VBox.vgrow="ALWAYS">
      <children>
        <TableView fx:id="reportTable" layoutX="14.0" layoutY="14.0" prefHeight="380.0" prefWidth="760.0">
          <columns>
            <TableColumn fx:id="orderIdCol"    prefWidth="80.0"  text="Order ID" />
            <TableColumn fx:id="customerCol"   prefWidth="150.0" text="Customer" />
            <TableColumn fx:id="statusCol"     prefWidth="100.0" text="Status" />
            <TableColumn fx:id="totalCol"      prefWidth="100.0" text="Total" />
            <TableColumn fx:id="dateCol"       prefWidth="200.0" text="Date" />
          </columns>
        </TableView>
        <Button layoutX="14.0"  layoutY="410.0" text="Daily Report"  onAction="#dailyReport" />
        <Button layoutX="150.0" layoutY="410.0" text="Return Home"   onAction="#returnHome" />
      </children>
    </AnchorPane>
  </children>
</VBox>