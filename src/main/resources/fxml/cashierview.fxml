<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import java.lang.String?>
<VBox id="background"
      fx:id="background"
      fx:controller="com.boba.CashierController"
      maxHeight="-Infinity" maxWidth="1.7976931348623157E308"
      minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="480.0" prefWidth="660.0"
      styleClass="vbox-class"
      stylesheets="@cashierview.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1">

   <children>
      <FlowPane fx:id="menuGrid"
                prefWrapLength="640.0"
                hgap="6" vgap="6"
                VBox.vgrow="ALWAYS">
         <padding>
            <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
         </padding>
      </FlowPane>

      <Button fx:id="managerViewButton"
              alignment="CENTER"
              mnemonicParsing="false"
              onAction="#goToManagerView"
              styleClass="menubuttons"
              stylesheets="@cashierview.css"
              text="Manager View">
         <VBox.margin>
            <Insets top="5.0"/>
         </VBox.margin>
      </Button>

      <Button id="orderbutton"
              fx:id="orderButton"
              alignment="CENTER"
              mnemonicParsing="false"
              onAction="#submitOrder"
              stylesheets="@cashierview.css"
              text="Submit Order">
         <styleClass>
            <String fx:value="menubuttons"/>
            <String fx:value="orderbutton"/>
         </styleClass>
         <VBox.margin>
            <Insets top="10.0"/>
         </VBox.margin>
      </Button>

   </children>
</VBox>