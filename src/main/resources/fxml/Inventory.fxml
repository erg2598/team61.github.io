<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/25" 
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.boba.InventoryController" stylesheets="@managerview.css">
  <children>
    <AnchorPane VBox.vgrow="ALWAYS">
      <children>
        <TableView fx:id="inventoryTable" layoutX="14.0" layoutY="14.0" prefHeight="380.0" prefWidth="660.0">
          <columns>
            <TableColumn fx:id="idCol"        prefWidth="60.0"  text="ID" />
            <TableColumn fx:id="nameCol"      prefWidth="180.0" text="Name" />
            <TableColumn fx:id="qtyCol"       prefWidth="100.0" text="Quantity" />
            <TableColumn fx:id="priceCol"     prefWidth="100.0" text="Price/Unit" />
            <TableColumn fx:id="reorderCol"   prefWidth="100.0" text="Reorder At" />
            <TableColumn fx:id="typeCol"      prefWidth="100.0" text="Type" />
          </columns>
        </TableView>
        <Button layoutX="14.0"  layoutY="410.0" text="Refresh"       onAction="#loadTable" />
        <Button layoutX="120.0" layoutY="410.0" text="Add Item"       onAction="#addInventoryItem" />
        <Button layoutX="226.0" layoutY="410.0" text="Update Item"    onAction="#updateInventoryItem" />
        <Button layoutX="332.0" layoutY="410.0" text="Return Home"    onAction="#returnHome" />
      </children>
    </AnchorPane>
  </children>
</VBox>