<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.boba.ToggleMenuController"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="700.0"
            stylesheets="@cashierview.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1">

   <!-- TOP: Customer name bar -->
   <top>
      <HBox spacing="12.0" alignment="CENTER_LEFT"
            style="-fx-background-color: rgba(255,255,255,0.04); -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 0 0 1 0;">
         <padding>
            <Insets top="12.0" right="16.0" bottom="12.0" left="16.0"/>
         </padding>
         <Label text="Customer Name:"
                style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 14px; -fx-font-weight: bold;"/>
         <TextField fx:id="customerNameField"
                    promptText="Enter customer name"
                    prefWidth="240.0"
                    style="-fx-background-color: rgba(255,255,255,0.08);
                           -fx-text-fill: #ffffff;
                           -fx-prompt-text-fill: rgba(255,255,255,0.4);
                           -fx-border-color: rgba(255,255,255,0.2);
                           -fx-border-radius: 8px;
                           -fx-background-radius: 8px;
                           -fx-font-family: 'Segoe UI';
                           -fx-font-size: 13px;
                           -fx-padding: 6 10 6 10;"/>
      </HBox>
   </top>

   <!-- CENTER: All customisation options as flat VBox sections -->
   <center>
      <ScrollPane fitToWidth="true" fitToHeight="false"
                  style="-fx-background-color: transparent; -fx-background: transparent;">
         <content>
            <VBox spacing="0"
                  style="-fx-background-color: transparent;">

               <!-- BASES & FLAVORINGS -->
               <VBox spacing="0">
                  <Label text="Bases and Flavorings"
                         style="-fx-text-fill: #ffffff;
                                -fx-font-family: 'Segoe UI';
                                -fx-font-size: 13px;
                                -fx-font-weight: bold;
                                -fx-background-color: rgba(229,57,53,0.55);
                                -fx-padding: 8 16 8 16;">
                     <VBox.margin><Insets top="0"/></VBox.margin>
                  </Label>
                  <FlowPane fx:id="basesPane" hgap="10" vgap="8"
                            style="-fx-background-color: rgba(255,255,255,0.03);
                                   -fx-border-color: rgba(255,255,255,0.07);
                                   -fx-border-width: 0 0 1 0;">
                     <padding>
                        <Insets top="10.0" right="14.0" bottom="10.0" left="14.0"/>
                     </padding>
                  </FlowPane>
               </VBox>

               <!-- TOPPINGS -->
               <VBox spacing="0">
                  <Label text="Toppings  (select up to 5)"
                         style="-fx-text-fill: #ffffff;
                                -fx-font-family: 'Segoe UI';
                                -fx-font-size: 13px;
                                -fx-font-weight: bold;
                                -fx-background-color: rgba(229,57,53,0.55);
                                -fx-padding: 8 16 8 16;"/>
                  <FlowPane fx:id="toppingsPane" hgap="10" vgap="8"
                            style="-fx-background-color: rgba(255,255,255,0.03);
                                   -fx-border-color: rgba(255,255,255,0.07);
                                   -fx-border-width: 0 0 1 0;">
                     <padding>
                        <Insets top="10.0" right="14.0" bottom="10.0" left="14.0"/>
                     </padding>
                  </FlowPane>
               </VBox>

               <!-- SIZE -->
               <VBox spacing="0">
                  <Label text="Size"
                         style="-fx-text-fill: #ffffff;
                                -fx-font-family: 'Segoe UI';
                                -fx-font-size: 13px;
                                -fx-font-weight: bold;
                                -fx-background-color: rgba(229,57,53,0.55);
                                -fx-padding: 8 16 8 16;"/>
                  <HBox spacing="24" alignment="CENTER_LEFT"
                        style="-fx-background-color: rgba(255,255,255,0.03);
                               -fx-border-color: rgba(255,255,255,0.07);
                               -fx-border-width: 0 0 1 0;">
                     <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                     <RadioButton fx:id="regularSize" text="Regular"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                     <RadioButton fx:id="largeSize"   text="Large (+$2.00)"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                  </HBox>
               </VBox>

               <!-- ICE LEVEL -->
               <VBox spacing="0">
                  <Label text="Ice Level"
                         style="-fx-text-fill: #ffffff;
                                -fx-font-family: 'Segoe UI';
                                -fx-font-size: 13px;
                                -fx-font-weight: bold;
                                -fx-background-color: rgba(229,57,53,0.55);
                                -fx-padding: 8 16 8 16;"/>
                  <HBox spacing="24" alignment="CENTER_LEFT"
                        style="-fx-background-color: rgba(255,255,255,0.03);
                               -fx-border-color: rgba(255,255,255,0.07);
                               -fx-border-width: 0 0 1 0;">
                     <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                     <RadioButton fx:id="noIce"      text="None"    onAction="#toggleNoIce"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                     <RadioButton fx:id="lessIce"    text="Less"    onAction="#toggleLessIce"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                     <RadioButton fx:id="regularIce" text="Regular" onAction="#toggleRegularIce"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                  </HBox>
               </VBox>

               <!-- TEMPERATURE -->
               <VBox spacing="0">
                  <Label text="Temperature"
                         style="-fx-text-fill: #ffffff;
                                -fx-font-family: 'Segoe UI';
                                -fx-font-size: 13px;
                                -fx-font-weight: bold;
                                -fx-background-color: rgba(229,57,53,0.55);
                                -fx-padding: 8 16 8 16;"/>
                  <HBox spacing="24" alignment="CENTER_LEFT"
                        style="-fx-background-color: rgba(255,255,255,0.03);
                               -fx-border-color: rgba(255,255,255,0.07);
                               -fx-border-width: 0 0 1 0;">
                     <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                     <RadioButton fx:id="cold" text="Cold" onAction="#toggleCold"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                     <RadioButton fx:id="hot"  text="Hot"  onAction="#toggleHot"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                  </HBox>
               </VBox>

               <!-- SUGAR LEVEL -->
               <VBox spacing="0">
                  <Label text="Sugar Level"
                         style="-fx-text-fill: #ffffff;
                                -fx-font-family: 'Segoe UI';
                                -fx-font-size: 13px;
                                -fx-font-weight: bold;
                                -fx-background-color: rgba(229,57,53,0.55);
                                -fx-padding: 8 16 8 16;"/>
                  <HBox spacing="18" alignment="CENTER_LEFT"
                        style="-fx-background-color: rgba(255,255,255,0.03);">
                     <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                     <RadioButton fx:id="noSugar"      text="0%"   onAction="#toggleNoSugar"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                     <RadioButton fx:id="sugar25"      text="25%"  onAction="#toggleSugar25"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                     <RadioButton fx:id="sugar50"      text="50%"  onAction="#toggleSugar50"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                     <RadioButton fx:id="sugar75"      text="75%"  onAction="#toggleSugar75"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                     <RadioButton fx:id="regularSugar" text="100%" onAction="#toggleRegularSugar"
                                  style="-fx-text-fill: #ffffff; -fx-font-family: 'Segoe UI'; -fx-font-size: 13px;"/>
                  </HBox>
               </VBox>

            </VBox>
         </content>
      </ScrollPane>
   </center>

   <!-- BOTTOM: Action buttons -->
   <bottom>
      <HBox spacing="16" alignment="CENTER"
            style="-fx-background-color: rgba(255,255,255,0.04); -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1 0 0 0;">
         <padding>
            <Insets top="14.0" right="20.0" bottom="14.0" left="20.0"/>
         </padding>
         <Button fx:id="backButton"
                 mnemonicParsing="false"
                 onAction="#backToMenu"
                 text="← Back"
                 prefWidth="160" prefHeight="44"/>
         <Button fx:id="addToCart"
                 mnemonicParsing="false"
                 onAction="#addItem"
                 text="Add to Cart"
                 prefWidth="200" prefHeight="44"
                 styleClass="orderbutton"/>
      </HBox>
   </bottom>

</BorderPane>